# ============================================================
# StudyForge Pro — 环境变量配置参考
# ============================================================
# 使用方式:
#   1. 复制本文件为 .env:  cp .env.example .env
#   2. 填入实际值
#   3. 启动前加载: source .env && ./studyforge
#   或者: 在 config.yaml 中直接配置（见 config.yaml.example）
#
# 优先级: 环境变量 > config.yaml > 内置默认值
# ============================================================

# ── 配置文件路径 ────────────────────────────────────────────
# 指定 config.yaml 的路径（默认为当前目录下的 config.yaml）
# CONFIG_PATH=./config.yaml

# ── 服务器 ─────────────────────────────────────────────────
# 监听地址（默认 0.0.0.0）
# SERVER_HOST=0.0.0.0
# 监听端口（默认 8080）
# SERVER_PORT=8080

# ── 数据库 ─────────────────────────────────────────────────
# SQLite 数据库文件路径（默认 ./data/studyforge.db）
# DB_PATH=./data/studyforge.db

# ── JWT 认证 ───────────────────────────────────────────────
# JWT 签名密钥（必填！请替换为随机强密钥）
# JWT_SECRET=your-random-secret-here
# JWT 过期时间，单位：小时（默认 72）
# JWT_EXPIRE_HOURS=72

# ── LLM / AI 模型 ─────────────────────────────────────────
# LLM API Key（必填！通义千问 DashScope API Key）
# 获取方式: https://dashscope.console.aliyun.com/
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM API 基础 URL（默认: 通义千问兼容模式）
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 对话模型名称（默认 qwen-plus）
# LLM_MODEL=qwen-plus
# 文本向量化模型名称（默认 text-embedding-v3）
# LLM_EMBEDDING_MODEL=text-embedding-v3

# ── Qdrant 向量数据库 ──────────────────────────────────────
# Qdrant 主机地址（默认 localhost）
# QDRANT_HOST=localhost
# Qdrant 端口（默认 6333）
# QDRANT_PORT=6333
# 向量集合名称（默认 studyforge_docs）
# QDRANT_COLLECTION=studyforge_docs
# 向量维度（默认 1024，需与 embedding 模型匹配）
# QDRANT_VECTOR_SIZE=1024

# ── RAG 检索参数 ──────────────────────────────────────────
# 文档分块大小（字符数，默认 400）
# RAG_CHUNK_SIZE=400
# 分块重叠大小（字符数，默认 50）
# RAG_CHUNK_OVERLAP=50
# 检索返回条数（默认 5）
# RAG_TOP_K=5

# ── CORS 跨域 ──────────────────────────────────────────────
# 额外的允许 Origin，逗号分隔（默认已包含 localhost:5173/8080）
# CORS_ORIGINS=https://yourdomain.com,https://another.com
